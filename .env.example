# ============================================
# ENVIRONMENT CONFIGURATION - UI WEB R&D
# ============================================
# Copy this file to .env.local and fill with your actual values

# ============================================
# DATABASE CONFIGURATION - SQL SERVER
# ============================================
# SQL Server address (can be IP or hostname)
DB_SERVER=your_server_ip_or_hostname

# Database name
DB_DATABASE=db_SampelKain

# Database user
DB_USER=sa

# Database password
DB_PASSWORD=your_password_here

# Database port (default: 1433)
DB_PORT=1433

# Encrypt connection
DB_ENCRYPT=true

# Trust self-signed certificate (set true for local SQL Server)
DB_TRUST_SERVER_CERTIFICATE=true

# Optional: TLS Server Name (recommended if DB_SERVER is IP address)
# DB_TLS_SERVER_NAME=sqlserver.local

# ============================================
# MASTER PRODUK TABLE - COLUMN MAPPING
# ============================================
DB_TABLE=Master_Produk
DB_COL_ID=ID_Sampel
DB_COL_DESIGN=Design
DB_COL_LEMARI=Lemari
DB_COL_RAK_HANGER=Rak_Hanger
DB_COL_BRAND_NOTE=Brand_Name_NOTE

# ============================================
# SPESIFIKASI TABLE - COLUMN MAPPING
# ============================================
DB_SPESIFIKASI_TABLE=Spesifikasi
DB_COL_SPESIFIKASI_ID=ID_Benang
DB_COL_SPESIFIKASI_ID_SAMPEL=ID_Sampel
DB_COL_BENANG_LUSI=Benang_Lusi
DB_COL_BENANG_PAKAN=Benang_Pakan
DB_COL_POLY=Poly
DB_COL_CD=CD
DB_COL_RAY=Ray
DB_COL_RW=RW
DB_COL_RF=RF
DB_COL_NYL=Nyl
DB_COL_PU=PU
DB_COL_ROS=Ros
DB_COL_TAC=Tac
DB_COL_DOPE=Dope

# ============================================
# KONSTRUKSI TENUN TABLE - COLUMN MAPPING
# ============================================
DB_KONSTRUKSI_TABLE=Konstruksi_Tenun
DB_COL_KONSTRUKSI_ID=ID_Konstruksi
DB_COL_KONSTRUKSI_ID_SAMPEL=ID_Sampel
DB_COL_WEAVE_CONSTR=Weave_Constr
DB_COL_DENSITY_WARP=Density_Warp
DB_COL_DENSITY_WEFT=Density_Weft

# ============================================
# PARAMETER FISIK TABLE - COLUMN MAPPING
# ============================================
DB_PARAMETER_FISIK_TABLE=Parameter_Fisik
DB_COL_FISIK_ID=ID_Fisik
DB_COL_FISIK_ID_SAMPEL=ID_Sampel
DB_COL_WIDTH_CM=Width_Cm
DB_COL_LEBAR_ACT=Lebar_Act
DB_COL_BERAT_BULATAN=Berat_Bulatan
DB_COL_GR_L_YD=Gr_L_Yd
DB_COL_GR_SQM=Gr_Sqm
DB_COL_GR_L_MTR=Gr_L_Mtr
DB_COL_GR_SQ_YD=Gr_SqYd
DB_COL_OZ_L_YD=Oz_LYd
DB_COL_OZ_SQ_YD=Oz_SqYd
DB_COL_LYD_58_INCH=LYd_58_inch

# ============================================
# EXTERNAL API CONFIGURATION
# ============================================
# FastAPI Backend URL
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8001

# ============================================
# SESSION & SECURITY
# ============================================
# Secret key for session signing (use random string for production)
SESSION_SECRET=your-session-secret-key
# Session cookie and issuer (must be unique per app)
SESSION_COOKIE_NAME=auth_session_rnd_v1
SESSION_ISSUER=ui_web_rnd

# ============================================
# WEB PUSH NOTIFICATIONS (PWA)
# ============================================
# VAPID keys for Web Push Notification
# Must be same as ui_ambil_sampel for inter-system notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:admin@example.com

